# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Web/Android API key used to initialize Firebase services.
FIREBASE_API_KEY=PLACEHOLDER_FIREBASE_API_KEY

# FIREBASE_PROJECT_ID: The unique identifier of your Firebase/GCP project.
FIREBASE_PROJECT_ID=PLACEHOLDER_FIREBASE_PROJECT_ID

# FIREBASE_APPLICATION_ID: The mobile SDK application ID for this app.
FIREBASE_APPLICATION_ID=PLACEHOLDER_FIREBASE_APPLICATION_ID

# FIREBASE_STORAGE_BUCKET: The Cloud Storage bucket URL for Firebase files.
FIREBASE_STORAGE_BUCKET=PLACEHOLDER_FIREBASE_STORAGE_BUCKET
